FIREBASE_PROJECT_ID=ridgits-24f2d
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
APP_STORE_BUNDLE_ID=com.ridgits.app
# Production numeric App Store app ID (required for Production IAP JWS verification).
APP_STORE_APP_APPLE_ID=
# Sandbox | Production (defaults to Production). TestFlight purchases use Sandbox JWS even against production API.
APP_STORE_ENVIRONMENT=Production
# Comma-separated extra hosts allowed for profile photo URL fetches (Firebase Storage is always allowed).
RIDGITS_PROFILE_PHOTO_ALLOWED_HOSTS=
RIDGITS_BYPASS_EMAILS=reviewer@example.com,qa@ridgits.com
# Account emails manually approved for profile photo ↔ ID match after ops review (comma-separated).
# Add an email here when automated face match fails (e.g. past Stripe's 48-hour selfie window).
RIDGITS_MANUAL_PHOTO_VERIFIED_EMAILS=
CRON_SECRET=

# --- Trust & safety (see TRUST_SAFETY.md) ---
# Extra disposable-email domains to block beyond the maintained `disposable-email-domains` list.
RIDGITS_EXTRA_DISPOSABLE_DOMAINS=
# Domains to always allow even if flagged by the disposable list (rare false positives).
RIDGITS_ALLOWED_EMAIL_DOMAINS=
# Hours a new account must exist before it can poke/message.
RIDGITS_MIN_ACCOUNT_AGE_HOURS=24
# Salt used to hash phone numbers before storing (never store raw phone numbers).
RIDGITS_PHONE_HASH_SALT=
RIDGITS_PROFILE_PHOTO_HASH_SALT=
RIDGITS_IDENTITY_DOCUMENT_HASH_SALT=
# Number of distinct accounts on one device fingerprint before flagging as multi-account abuse.
RIDGITS_DEVICE_MULTI_ACCOUNT_THRESHOLD=3
# Set to "true" to HEAD-request profile photo URLs to confirm they resolve to an image.
RIDGITS_PHOTO_HEAD_CHECK=false
# Optional NSFW/content moderation provider for profile photos ("sightengine" or unset).
RIDGITS_MODERATION_PROVIDER=
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
# Stripe Identity (iOS subscription gate — verification only, not payment on iOS).
STRIPE_SECRET_KEY=
# Restricted key (rk_live_... / rk_test_...) for selfie/document images during profile photo face match.
# Dashboard → API keys → Create restricted key → Identity: Verification Sessions and Reports (Read),
# Access recent sensitive verification results (Read), Files (Write).
# https://docs.stripe.com/identity/access-verification-results
STRIPE_IDENTITY_RESTRICTED_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_IDENTITY_RETURN_URL=https://ridgits.com/identity/complete
# Stripe Dashboard → Identity → Verification flows → copy flow ID (vf_...). Flow must include phone OTP.
STRIPE_IDENTITY_VERIFICATION_FLOW_ID=
# Require OTP phone verification inside Stripe Identity (default on; set false to disable).
RIDGITS_IDENTITY_REQUIRE_PHONE=true
# Minimum face similarity (0–1) between profile photo and verified Stripe selfie.
RIDGITS_IDENTITY_FACE_MATCH_THRESHOLD=0.90
# Amazon Rekognition CompareFaces (profile photo vs verified Stripe selfie).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Optional Twilio Lookup credentials for VOIP/line-type checks (phone verification prep).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
